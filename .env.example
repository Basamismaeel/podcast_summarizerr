# Copy to `.env` and fill in real values. Never commit `.env`.
#
# GEMINI_API_KEY must be from https://aistudio.google.com/apikey
# (string starts with "AIza"). Do not paste Deepgram/OpenAI/other keys here.

GEMINI_API_KEY=
# Optional: v1beta (default) or v1 — must match Google Generative Language REST docs
# GEMINI_API_VERSION=v1beta
TADDY_API_KEY=
TADDY_USER_ID=
DEEPGRAM_API_KEY=
TRANSCRIPTION_PROVIDER=deepgram
API_BASE_URL=
